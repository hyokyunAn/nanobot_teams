# Teams / Azure Bot credentials
MicrosoftAppId=
MicrosoftAppPassword=
MicrosoftAppType=SingleTenant
MicrosoftAppTenantId=

# Backend bind
PORT=3978
APP_BIND_HOST=
GUNICORN_BIND=:${PORT}

# nanobot relay inbound endpoint
NANOBOT_INBOUND_URL=
NANOBOT_INBOUND_HOST=
NANOBOT_TIMEOUT_SEC=120
NANOBOT_VERIFY_SSL=false

# Shared internal auth token
INTERNAL_TOKEN=

# Conversation reference store path
REFERENCE_STORE_PATH=./data/conversation_references.json
